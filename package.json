{
  "name": "vark-ui-platform",
  "version": "0.0.0",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "lint:affected": "nx affected -t lint --base=origin/main --head=HEAD",
    "lint:affected:local": "nx affected -t lint --base=origin/main --uncommited",
    "typecheck:affected": "nx affected -t typecheck --base=origin/main --head=HEAD",
    "typecheck:affected:local": "nx affected -t typecheck --base=origin/main --uncommited && format:affected:check",
    "build:affected": "nx affected -t build --base=origin/main --head=HEAD",
    "build:affected:local": "nx affected -t build --base=origin/main --uncommited",
    "test:affected": "nx affected -t test --base=origin/main --head=HEAD",
    "test:affected:local": "nx affected -t test --base=origin/main --uncommited",
    "check:affected": "npm run lint:affected && npm run typecheck:affected && nx format:check --affected --base=main --head=HEAD",
    "check:affected:local": "npm run lint:affected:local && npm run typecheck:affected:local",
    "format:affected": "nx format:write --base=origin/main --head=HEAD --sort-root-tsconfig-paths=false && git diff -z --name-only --diff-filter=ACMR origin/main...HEAD | xargs -0 -r prettier --write || echo \"No affected files\"",
    "format:affected:check": "nx format:check --base=origin/main --head=HEAD --sort-root-tsconfig-paths=false && git diff -z --name-only --diff-filter=ACMR origin/main...HEAD | xargs -0 -r prettier --check || echo \"No affected files\"",
    "check:all": "npm run lint:all && npm run typecheck:all",
    "format:all": "nx format:write --all --sort-root-tsconfig-paths=false",
    "format:check:all": "nx format:check --all --sort-root-tsconfig-paths=false",
    "lint:all": "nx run-many --target=lint --all",
    "typecheck:all": "nx run-many --target=typecheck --all"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "~20.2.0",
    "@angular/compiler": "~20.2.0",
    "@angular/core": "~20.2.0",
    "@angular/forms": "~20.2.0",
    "@angular/platform-browser": "~20.2.0",
    "@angular/router": "~20.2.0",
    "rxjs": "~7.8.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "~0.2002.2",
    "@angular-devkit/core": "~20.2.0",
    "@angular-devkit/schematics": "~20.2.0",
    "@angular/build": "~20.2.0",
    "@angular/cli": "~20.2.0",
    "@angular/compiler-cli": "~20.2.0",
    "@angular/language-service": "~20.2.0",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "22.5.3",
    "@nx/devkit": "22.5.3",
    "@nx/eslint": "22.5.3",
    "@nx/eslint-plugin": "22.5.3",
    "@nx/js": "22.5.3",
    "@nx/playwright": "22.5.3",
    "@nx/web": "22.5.3",
    "@nx/workspace": "22.5.3",
    "@playwright/test": "^1.36.0",
    "@schematics/angular": "~20.2.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^20.2.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.5.3",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.40.0"
  }
}
