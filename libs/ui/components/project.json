{
  "name": "ui-components",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ui/components",
  "projectType": "library",
  "tags": ["scope:ui", "type:ui"],
  "// targets": "to see all targets run: nx show project ui-components --web",
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/ui/components/src/index.ts"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --project libs/ui/components/tsconfig.json"
      }
    }
  }
}
